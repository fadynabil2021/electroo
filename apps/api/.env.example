# Node Environment
NODE_ENV=production
PORT=3011
FRONTEND_URL=https://your-vercel-domain.vercel.app
ADMIN_URL=https://your-vercel-domain.vercel.app
API_BASE_URL=https://your-railway-domain.up.railway.app

# 5. Supabase PostgreSQL Connection
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# 12. Upstash Redis Connection
REDIS_URL="rediss://default:[YOUR_UPSTASH_PASSWORD]@active-upstash-redis-url.upstash.io:6379"

# JWT Auth
JWT_ACCESS_SECRET="generate-a-strong-256-bit-long-random-string-for-access-tokens"
JWT_REFRESH_SECRET="generate-another-strong-256-bit-long-random-string-for-refresh-tokens"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# 10. Paymob Integration credentials
PAYMOB_API_KEY="zx_api_key_obtained_from_paymob_settings..."
PAYMOB_INTEGRATION_ID_CARD="123456" # Credit Card integration ID
PAYMOB_INTEGRATION_ID_FAWRY="123457" # Fawry integration ID
PAYMOB_IFRAME_ID="12345" # Iframe ID configured in Paymob
PAYMOB_HMAC_SECRET="your_paymob_hmac_secret_for_webhook_validation"
PAYMOB_CALLBACK_URL="https://your-railway-domain.up.railway.app/api/v1/payments/webhook"

# 16. Twilio SMS Configuration (OTP)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_FROM_NUMBER="+1xxxxxxxxxx"

# 15. Resend Transactional Email Configuration
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Alex Food <orders@yourdomain.com>"

# 8. Cloudinary Image Upload
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# 13. Sentry Error Monitoring
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxx@o4500000000000000.ingest.us.sentry.io/4500000000000000"
